{
  "name": "merng-social-network",
  "version": "0.0.1",
  "description": "social network prototype using the MERNG stack.",
  "private": true,
  "packageManager": "pnpm@9.15.1",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "start": "turbo run start",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "server": "pnpm --filter @hiworld/server dev",
    "client": "pnpm --filter @hiworld/client dev"
  },
  "author": "tverderesi",
  "license": "ISC",
  "devDependencies": {
    "turbo": "^2.9.6"
  }
}
