MONGODB_URI=mongodb://localhost:27017/merng
SECRET_KEY=replace-with-a-strong-secret
POST_RATE_LIMIT_MAX_POSTS=5
POST_RATE_LIMIT_WINDOW_SECONDS=60
PASSWORD_RESET_URL_BASE=http://hiworld.social

# Use `resend` for real email delivery. Docker dev overrides this to Mailpit.
EMAIL_TRANSPORT=resend

# Only used when EMAIL_TRANSPORT=smtp, typically with local Mailpit.
SMTP_HOST=localhost
SMTP_PORT=1025

# Replace re_xxxxxxxxx with your real Resend API key.
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
