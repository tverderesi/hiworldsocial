{
  "name": "@hiworld/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false index.ts",
    "start": "node dist/index.js",
    "db:setup": "tsx scripts/setup-db.ts",
    "codegen": "graphql-codegen --config codegen.ts",
    "export-schema": "tsx scripts/export-schema.ts",
    "build": "tsc -p tsconfig.json && cp graphql/schema.graphql dist/graphql/schema.graphql",
    "test": "vitest run"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.25",
    "apollo-server": "^3.13.0",
    "apollo-server-core": "^3.13.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "graphql": "^16.13.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "nodemailer": "^6.10.1",
    "resend": "^4.8.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/typescript": "^5.0.6",
    "@graphql-codegen/typescript-resolvers": "^5.1.8",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^6.4.21",
    "@types/node": "^24.10.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
